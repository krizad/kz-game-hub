{
  "name": "kz-game-hub",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "pnpm -F @repo/database db:generate",
    "db:migrate": "pnpm -F @repo/database db:migrate",
    "db:push": "pnpm -F @repo/database db:push",
    "db:studio": "pnpm -F @repo/database db:studio",
    "db:seed": "pnpm -F @repo/database db:seed",
    "start": "turbo run start"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@9.1.0"
}