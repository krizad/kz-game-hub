# ==========================================
# Root Configuration for the kz-game-hub
# ==========================================

# Web Frontend (apps/web)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# API Backend (apps/api)
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# Database Configuration (packages/database)
# For Supabase, use the Session connection string (Transaction pooler is not needed since our backend uses pg.Pool)
# Format: postgresql://[db-user].[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:5432/[db-name]
DATABASE_URL="postgresql://postgres:password@localhost:5432/kz_game_hub"

# Google Gemini API
GEMINI_API_KEY="your-gemini-api-key"

# Spotify API (for Music Trivia game)
# Get credentials from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"

# YouTube API (for Music Trivia game)
# Get credentials from: https://console.cloud.google.com/
YOUTUBE_API_KEY="your-youtube-api-key"
