generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoomStatus {
  LOBBY
  WORD_SETTING
  QUESTIONING
  VOTING
  RESULT
}

enum Role {
  Host
  Know
  Unknow
}

model Room {
  id         String     @id @default(uuid())
  code       String     @unique
  status     RoomStatus @default(LOBBY)
  roomHostId String
  players    User[]
  createdAt  DateTime   @default(now())
}

model User {
  id       String  @id @default(uuid())
  name     String
  socketId String  @unique
  role     Role?
  score    Int     @default(0)
  roomId   String
  room     Room    @relation(fields: [roomId], references: [id])
}

model SoundsFishyQuestion {
  id          String @id @default(uuid())
  question    String
  answer      String
  lang        String @default("th")
  query_count Int    @default(0)
}

model Word {
  id       String  @id @default(uuid())
  word     String
  category String
  emoji    String?
  lang     String  @default("en")

  @@index([category, lang])
}
